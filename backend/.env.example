# Copy to backend/.env and adjust. All vars are prefixed SCS_.

# Postgres in production:
# SCS_DATABASE_URL=postgresql+psycopg://scs:scs@localhost:5432/scs
# SQLite default (no infra) is used if unset.

# Object storage root for assets + provenance manifests.
# SCS_STORAGE_DIR=./storage

# Private key used to sign provenance manifests (HMAC). MUST be set in prod.
SCS_PROVENANCE_SIGNING_KEY=change-me

# Visible label baked into every emitted asset.
SCS_DISCLOSURE_LABEL_TEXT=AI · SYNTHETIC

# Celery / Redis (queue layer).
# SCS_BROKER_URL=redis://localhost:6379/0
# SCS_RESULT_BACKEND=redis://localhost:6379/1
