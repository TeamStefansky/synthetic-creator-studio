{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/monitor",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/watch/scan",
      "schedule": "0 6 * * *"
    }
  ]
}
