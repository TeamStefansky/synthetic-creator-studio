{
  "name": "truthlens",
  "version": "0.1.0",
  "private": true,
  "description": "TruthLens — detect likely fake-news websites and expose the infrastructure behind them. Decision-support tool, not a verdict.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "check:tokens": "grep -rnE \"#[0-9a-fA-F]{3,8}\\b\" app components --include=*.tsx --include=*.ts | grep -vE \"lib/design-tokens|globals.css\" || echo NONE"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cheerio": "^1.0.0",
    "lucide-react": "^0.460.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.27.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
