# ============================================================================
# TruthLens environment variables
# Copy this file to `.env.local` and fill in what you have.
# ALL core infrastructure features work WITHOUT any keys (free public APIs).
# Keys only unlock optional / higher-quality layers.
# ============================================================================

# Required ONLY for the content-credibility layer (Anthropic / Claude).
# Without it, the content-analysis card is skipped and confidence is lower —
# everything else (DNS/WHOIS/IP/SSL/archive/graph/scoring) still works.
ANTHROPIC_API_KEY=

# Optional: Google Fact Check Tools API key. Improves the reputation layer.
GOOGLE_FACTCHECK_KEY=

# Optional: ipinfo.io token. Raises IP/ASN/geo rate limits and accuracy.
# Without it the app falls back to ip-api.com (free, throttled).
IPINFO_TOKEN=

# Optional: web search key for the content-propagation tracer (open-web only).
# Without it, propagation tracing relies on Wayback + is marked limited.
SEARCH_API_KEY=

# Optional (PAID): reverse-image search (TinEye / Google Vision). Disabled if empty.
IMAGE_SEARCH_KEY=

# Optional (PAID/limited): social API (e.g. X/Twitter) for amplification signals.
SOCIAL_API_KEY=
