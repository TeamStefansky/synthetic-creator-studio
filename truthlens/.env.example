# ============================================================================
# TruthLens environment variables
# Copy this file to `.env.local` and fill in what you have.
# ALL core infrastructure features work WITHOUT any keys (free public APIs).
# Keys only unlock optional / higher-quality layers.
# ============================================================================

# Optional: lock the whole site behind a shared password (HTTP Basic Auth).
# When set, visitors must enter any username + this password. Leave empty to
# keep the site open. Never commit a real value — set it in the host's env vars.
SITE_PASSWORD=

# Required ONLY for the content-credibility layer (Anthropic / Claude).
# Without it, the content-analysis card is skipped and confidence is lower —
# everything else (DNS/WHOIS/IP/SSL/archive/graph/scoring) still works.
ANTHROPIC_API_KEY=

# Optional: Google Fact Check Tools API key. Improves the reputation layer.
GOOGLE_FACTCHECK_KEY=

# Optional: ipinfo.io token. Raises IP/ASN/geo rate limits and accuracy.
# Without it the app falls back to ip-api.com (free, throttled).
IPINFO_TOKEN=

# Optional: Open PageRank API key (free at https://www.domcop.com/openpagerank/).
# Adds a 0-10 domain-authority signal to the legitimacy layer. Without it,
# authority is still estimated from domain age + Wayback longevity.
OPENPAGERANK_KEY=

# Optional: web search key for the content-propagation tracer (open-web only).
# Without it, propagation tracing relies on Wayback + is marked limited.
SEARCH_API_KEY=

# Optional (PAID): reverse-image search (TinEye / Google Vision). Disabled if empty.
IMAGE_SEARCH_KEY=

# ---- Social & Media Intelligence (Cyabra-style; all optional/paid) ----------
# X (Twitter) API v2 Bearer token — amplification + bot analysis on the report.
X_BEARER_TOKEN=

# AI-generated / deepfake IMAGE detection. Primary: Sightengine (both needed).
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
# Fallback image provider: Hive.
HIVE_API_KEY=

# ---- Monitoring & alerts (Vercel Cron hits /api/monitor daily) --------------
# Comma-separated domains to watch, e.g. "example.com,foo.co.il"
MONITOR_DOMAINS=
# Slack-compatible incoming webhook; receives an alert when a watched site is HIGH RISK.
ALERT_WEBHOOK_URL=
# If set, /api/monitor requires "Authorization: Bearer <CRON_SECRET>" (Vercel Cron sends it).
CRON_SECRET=

# History store for change/spike detection in monitoring. Use EITHER Vercel KV
# (add the KV integration → it injects KV_REST_API_URL/TOKEN) OR Upstash Redis.
# Without it, monitoring falls back to current-state HIGH-RISK alerts only.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Narrative Intelligence platform (Stage 6 dashboard at /platform) --------
# URL of the deployed narrative-intel FastAPI service (no trailing slash).
# When unset, the /platform dashboard shows a "connect the platform" state.
NARRATIVE_API_URL=
# Optional API key if the platform is protected (matches its API_KEYS).
NARRATIVE_API_KEY=
