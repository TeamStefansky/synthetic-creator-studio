# TruthLens environment configuration.
# Copy this file to ".env.local" and fill in the keys you have.

# Required for the content-analysis layer (Anthropic / Claude).
# Without it, infrastructure exposure + scoring still work; only the
# content-credibility analysis is skipped and confidence is lowered.
ANTHROPIC_API_KEY=

# Optional. Enables Google Fact Check Tools reputation matching.
GOOGLE_FACTCHECK_KEY=

# Optional. Raises ipinfo.io rate limits and adds richer geo/ASN data.
# Used by the site report AND the attribution tools (log analyzer, email tracer).
IPINFO_TOKEN=

# ---- Attribution tools (all optional) --------------------------------------
# Core attribution features work without these:
#  - Log Analyzer & Email Tracer work out of the box (IP enrichment via the free
#    ipinfo.io / ip-api.com tiers; a token above just raises limits).
#  - Content-propagation tracing uses ANTHROPIC_API_KEY with web search enabled.
#
# Reserved for optional paid integrations (skipped gracefully if absent):
SEARCH_API_KEY=        # optional external web-search provider for propagation
IMAGE_SEARCH_KEY=      # optional reverse-image search (TinEye / Google Vision)
SOCIAL_API_KEY=        # optional social API for synchronized-posting detection
