# narrative-intel — copy to .env. All optional; defaults run on SQLite + mock data.

# Storage. SQLite by default; point at Postgres in production.
DATABASE_URL=sqlite:///./narrative.db

# Ingestion worker
POLL_INTERVAL_SECONDS=300
# gdelt/bluesky/hackernews/reddit are free & keyless (real search, no signup);
# x/telegram/newsapi need keys (else mock).
ENABLED_SOURCES=x,telegram,rss,newsapi,gdelt,bluesky,hackernews,reddit

# Optional real-source credentials (mock data is used when absent)
X_BEARER_TOKEN=
NEWSAPI_KEY=
TELEGRAM_BOT_TOKEN=

# Reddit works keyless (best-effort); set these for reliable OAuth access
# (create a free app at https://www.reddit.com/prefs/apps).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Free-key news / video / search sources (each inert until its key is set).
# See docs/DATA_SOURCES.md for signup links.
GUARDIAN_API_KEY=
NYT_API_KEY=
GNEWS_API_KEY=
NEWSDATA_API_KEY=
MEDIASTACK_API_KEY=
BRAVE_API_KEY=
YOUTUBE_API_KEY=

# Mastodon instance whose public timeline is monitored (keyless).
MASTODON_INSTANCE=mastodon.social

# Default keyword query used when the dashboard search box is empty (and by the
# scheduled pipeline). The /api/search endpoint overrides this per request.
X_QUERY=disinformation OR fake news
RSS_FEEDS=

# GDELT (free global news search — no key needed)
GDELT_TIMESPAN=3d
GDELT_MAX_RECORDS=75

# Alerts: default webhook (Slack-compatible {text}) for rules without their own
ALERT_WEBHOOK_URL=

# Public API: comma-separated API keys required on /api/* (empty = open)
API_KEYS=
