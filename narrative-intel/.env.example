# narrative-intel — copy to .env. All optional; defaults run on SQLite + mock data.

# Storage. SQLite by default; point at Postgres in production.
DATABASE_URL=sqlite:///./narrative.db

# Ingestion worker
POLL_INTERVAL_SECONDS=300
# gdelt is free/keyless real news search; x/telegram/newsapi need keys (else mock)
ENABLED_SOURCES=x,telegram,rss,newsapi,gdelt

# Optional real-source credentials (mock data is used when absent)
X_BEARER_TOKEN=
NEWSAPI_KEY=
TELEGRAM_BOT_TOKEN=

# Default keyword query used when the dashboard search box is empty (and by the
# scheduled pipeline). The /api/search endpoint overrides this per request.
X_QUERY=disinformation OR fake news
RSS_FEEDS=

# GDELT (free global news search — no key needed)
GDELT_TIMESPAN=3d
GDELT_MAX_RECORDS=75

# Alerts: default webhook (Slack-compatible {text}) for rules without their own
ALERT_WEBHOOK_URL=

# Public API: comma-separated API keys required on /api/* (empty = open)
API_KEYS=
